amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl" as rg
import "@azure/dbforpostgresql/flexibleserver.pkl" as pg
import "@azure/dbforpostgresql/firewallrule.pkl" as fw
import "@azure/dbforpostgresql/database.pkl" as db
import "@azure/dbforpostgresql/configuration.pkl" as cfg

import "./vars.pkl"

description {
    text = """
        PostgreSQL database for the infra-to-app demo.

        Provisions an Azure PostgreSQL Flexible Server with a public firewall
        rule, the miniflux database, and the hstore extension enabled.
        """
    confirm = true
}

local resourceGroup = new rg.ResourceGroup {
    label = "db-rg"
    name = "\(vars.projectName)-rg"
    location = vars.location
    tags {
        new azure.Tag { key = "project"; value = vars.projectName }
        new azure.Tag { key = "managed-by"; value = "formae" }
    }
}

local database = new pg.FlexibleServer {
    label = "pg-server"
    name = "\(vars.projectName)-pg"
    location = vars.location
    resourceGroupName = resourceGroup.res.name
    sku = new pg.SKU { name = "Standard_B1ms"; tier = "Burstable" }
    version = "16"
    administratorLogin = vars.adminLogin
    administratorLoginPassword = vars.adminPassword
    storage = new pg.Storage { storageSizeGB = 32; autoGrow = "Enabled" }
    backup = new pg.Backup { backupRetentionDays = 7; geoRedundantBackup = "Disabled" }
    highAvailability = new pg.HighAvailability { mode = "Disabled" }
    authConfig = new pg.AuthConfig { passwordAuth = "Enabled"; activeDirectoryAuth = "Disabled" }
    tags {
        new azure.Tag { key = "project"; value = vars.projectName }
        new azure.Tag { key = "managed-by"; value = "formae" }
    }
}

local allowAllRule = new fw.FirewallRule {
    label = "allow-all-rule"
    name = "AllowAll"
    resourceGroupName = resourceGroup.res.name
    serverName = database.res.name
    startIpAddress = "0.0.0.0"
    endIpAddress = "255.255.255.255"
}

local hstoreExtension = new cfg.Configuration {
    label = "hstore-extension"
    name = "azure.extensions"
    resourceGroupName = resourceGroup.res.name
    serverName = database.res.name
    value = "hstore"
}

local minifluxDb = new db.Database {
    label = "miniflux-db"
    name = "miniflux"
    resourceGroupName = resourceGroup.res.name
    serverName = database.res.name
    charset = "UTF8"
    collation = "en_US.utf8"
}

forma {
    vars.stack
    vars.target

    resourceGroup
    database
    allowAllRule
    hstoreExtension
    minifluxDb
}
