amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@gitlab/project/projectvariable.pkl" as projvar
import "@gitlab/project/projectpipeline.pkl" as pipeline
import "@gitlab/project/projectenvironment.pkl" as projenv
import "@gitlab/ci/pipeline.pkl" as CI

import "vars.pkl"

description {
    text = """
        Infrastructure-to-application pipeline demo (GitLab CI/CD).

        Provisions an Azure PostgreSQL database with formae, deploys Miniflux
        (RSS reader) as an Azure Container Instance, verifies the app is healthy,
        and loads 5 RSS feeds. A separate destroy stage tears everything down.

        Two formae plugins working together: GitLab manages the pipeline,
        Azure manages the infrastructure.
        """
    confirm = true
}

// --- Config variables ---

local projectNameVar = new projvar.Variable {
    label = "project-name"
    key = "PROJECT_NAME"
    value = vars.projectName
}

local azureRegionVar = new projvar.Variable {
    label = "azure-region"
    key = "AZURE_REGION"
    value = vars.azureRegion
}

// --- Masked variables (secrets) ---

local azureClientId = new projvar.Variable {
    label = "azure-client-id"
    key = "AZURE_CLIENT_ID"
    value = read("env:AZURE_CLIENT_ID")
    masked = true
}

local azureTenantId = new projvar.Variable {
    label = "azure-tenant-id"
    key = "AZURE_TENANT_ID"
    value = read("env:AZURE_TENANT_ID")
    masked = true
}

local azureSubscriptionId = new projvar.Variable {
    label = "azure-subscription-id"
    key = "AZURE_SUBSCRIPTION_ID"
    value = read("env:AZURE_SUBSCRIPTION_ID")
    masked = true
}

local postgresPassword = new projvar.Variable {
    label = "postgres-password"
    key = "POSTGRES_PASSWORD"
    value = read?("env:POSTGRES_PASSWORD") ?? "ChangeMe12345"
    masked = true
}

local acrPassword = new projvar.Variable {
    label = "acr-password"
    key = "ACR_PASSWORD"
    value = read("env:ACR_PASSWORD")
    masked = true
}

// --- Environments ---

local stagingEnv = new projenv.Environment {
    label = "staging-env"
    name = "staging"
    tier = "staging"
}

local productionEnv = new projenv.Environment {
    label = "production-env"
    name = "production"
    tier = "production"
}

// --- Typed CI/CD Pipeline ---

local deployPipeline = new pipeline.Pipeline {
    label = "deploy-pipeline"
    path = ".gitlab-ci.yml"

    stages = new { "provision"; "deploy"; "verify"; "destroy" }

    variables {
        ["FORMAE_VERSION"] = "0.83.0"
    }

    jobs {
        ["provision"] = new CI.Job {
            stage = "provision"
            image = "mcr.microsoft.com/azure-cli:latest"
            rules = new {
                new CI.Rule {
                    `if` = #"$CI_PIPELINE_SOURCE == "web" && $DEPLOY == "true""#
                }
            }
            script = new {
                #"curl -fsSL https://hub.platform.engineering/setup/formae.sh | bash -s -- -y"#
                "export PATH=/opt/pel/formae/bin:$PATH"
                #"az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID"#
                "pkl project resolve infra"
                """
                formae agent start &
                for i in $(seq 1 30); do
                  if formae plugin list 2>/dev/null | grep -q AZURE; then
                    echo "Azure plugin ready"
                    break
                  fi
                  sleep 2
                done
                """
                "formae apply --mode reconcile --yes --watch infra/database.pkl"
            }
            artifacts = new CI.Artifacts {
                reports = new CI.Reports {
                    dotenv = "deploy.env"
                }
            }
        }
        ["deploy-app"] = new CI.Job {
            stage = "deploy"
            image = "mcr.microsoft.com/azure-cli:latest"
            needs = new { "provision" }
            rules = new {
                new CI.Rule {
                    `if` = #"$CI_PIPELINE_SOURCE == "web" && $DEPLOY == "true""#
                }
            }
            script = new {
                #"az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID"#
                #"""
                az container create \
                  --resource-group ${PROJECT_NAME}-rg \
                  --name miniflux-demo \
                  --dns-name-label ${PROJECT_NAME} \
                  --image formaedemoacr.azurecr.io/miniflux:2.2.19 \
                  --registry-login-server formaedemoacr.azurecr.io \
                  --registry-username formaedemoacr \
                  --registry-password "$ACR_PASSWORD" \
                  --os-type Linux --cpu 1 --memory 1 --ports 8080 \
                  --ip-address Public \
                  --environment-variables \
                    DATABASE_URL="postgres://pgadmin:${POSTGRES_PASSWORD}@${PROJECT_NAME}-pg.postgres.database.azure.com:5432/miniflux?sslmode=require" \
                    RUN_MIGRATIONS=1 CREATE_ADMIN=1 \
                    ADMIN_USERNAME=admin ADMIN_PASSWORD=demo1234 \
                    LISTEN_ADDR=0.0.0.0:8080
                """#
                #"APP_FQDN=$(az container show --resource-group ${PROJECT_NAME}-rg --name miniflux-demo --query 'ipAddress.fqdn' -o tsv)"#
                #"echo "APP_URL=http://$APP_FQDN:8080" >> deploy.env"#
            }
            artifacts = new CI.Artifacts {
                reports = new CI.Reports {
                    dotenv = "deploy.env"
                }
            }
        }
        ["verify"] = new CI.Job {
            stage = "verify"
            image = "curlimages/curl:latest"
            needs = new { "deploy-app" }
            rules = new {
                new CI.Rule {
                    `if` = #"$CI_PIPELINE_SOURCE == "web" && $DEPLOY == "true""#
                }
            }
            script = new {
                """
                for i in $(seq 1 60); do
                  if curl -sf "$APP_URL/healthcheck" > /dev/null 2>&1; then
                    echo "Miniflux is ready"
                    break
                  fi
                  echo "Waiting... ($i/60)"
                  sleep 2
                done
                """
                #"""
                for feed in \
                  "https://hnrss.org/best" \
                  "https://thenewstack.io/feed/" \
                  "https://tldr.tech/api/rss/devops" \
                  "https://hackernoon.com/feed" \
                  "https://xkcd.com/rss.xml"; do
                  for attempt in $(seq 1 5); do
                    if curl -sf -X POST "$APP_URL/v1/feeds" \
                      -u admin:demo1234 \
                      -H "Content-Type: application/json" \
                      -d "{\"feed_url\": \"$feed\", \"category_id\": 1}"; then
                      break
                    fi
                    echo "Retrying feed $feed ($attempt/5)..."
                    sleep 3
                  done
                done
                """#
                #"curl -sf -X PUT "$APP_URL/v1/feeds/refresh" -u admin:demo1234"#
                #"FEED_COUNT=$(curl -sf "$APP_URL/v1/feeds" -u admin:demo1234 | jq 'length')"#
                #"echo "Feed count: $FEED_COUNT""#
                #"[ "$FEED_COUNT" -eq 5 ] || exit 1"#
            }
        }
        ["destroy"] = new CI.Job {
            stage = "destroy"
            image = "mcr.microsoft.com/azure-cli:latest"
            rules = new {
                new CI.Rule {
                    `if` = #"$CI_PIPELINE_SOURCE == "web" && $DESTROY == "true""#
                }
            }
            script = new {
                #"az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID"#
                #"az container delete --resource-group ${PROJECT_NAME}-rg --name miniflux-demo --yes || true"#
                #"curl -fsSL https://hub.platform.engineering/setup/formae.sh | bash -s -- -y"#
                "export PATH=/opt/pel/formae/bin:$PATH"
                "pkl project resolve infra"
                """
                formae agent start &
                for i in $(seq 1 30); do
                  if formae plugin list 2>/dev/null | grep -q AZURE; then
                    echo "Azure plugin ready"
                    break
                  fi
                  sleep 2
                done
                formae destroy --yes --watch infra/database.pkl
                """
            }
        }
    }
}

forma {
    vars.stack
    vars.target

    deployPipeline

    projectNameVar
    azureRegionVar

    azureClientId
    azureTenantId
    azureSubscriptionId
    postgresPassword
    acrPassword

    stagingEnv
    productionEnv
}
